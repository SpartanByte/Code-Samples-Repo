
<div class="container w-50 mt-5">
    <div class="row">
        <div class="col-md-6">
            <h1 class="mt-5">Information Technology Articles</h1>
        </div>
    </div>
    <div class="row">
        <div class="col-md-6">
            <h3 class="mt-5">Articles for <%= @issue.issue_date.strftime("%m/%d/%Y") %> Issue</h3>
        </div>
        <div class="col-md-6 text-right">
            <h1 class="mt-5"><%= link_to "Create Article", new_article_path(issue: @issue), class: "btn btn-primary"%></h1>
        </div>
    </div>
    <%= react_component("articles/ArticlesIndexTable", {
            articles: @articles,
            articlePath: articles_path,
            csrfToken: form_authenticity_token
        })
    %>
    <%= link_to "Back to Issues", magazine_issues_path(magazine_id: @issue.magazine_id), class:"btn btn-primary"%>
</div>