<div class="container w-50 mt-5">
    <div class="row">
        <div class="col-md-6">
            <h1 class="mt-5">Ruby on Rails: Example Article</h1>
        </div>
    </div>
    <%= react_component("articles/ArticleShowContainer", {
            article: @article
        })
    %>
    <%= link_to "Back", articles_path(issue: @article.issue.id), class:"btn btn-secondary"%>
    <%= link_to "Edit", edit_article_path(@article), class:"btn btn-secondary"%>
</div>